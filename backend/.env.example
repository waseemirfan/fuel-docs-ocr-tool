# Choose your LLM provider: gemini | ollama | openrouter
LLM_PROVIDER=gemini

# --- Gemini (FREE tier - recommended) ---
# Get free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenRouter (optional paid alternative) ---
# Get key at: https://openrouter.ai
# OPENROUTER_API_KEY=your_openrouter_key_here
# LLM_MODEL=google/gemini-2.5-flash   # or any vision model on openrouter

# --- Ollama (optional local, no internet needed) ---
# LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# LLM_MODEL=qwen2.5vl:7b

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ocr.db
